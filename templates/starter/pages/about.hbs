<div>
  <!-- Page Hero (centered) -->
  <section class="relative overflow-hidden py-20 md:py-28 px-6">
    {{> hero-decorations showGrid=true patternId="about"}}
    <div class="relative max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white border border-gray-200 text-gray-500 text-xs font-semibold uppercase tracking-wider mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-violet-500"></span>
        About Us
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-950 tracking-[-0.02em] leading-[1.08]" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
        About {{site.businessName}}
      </h1>
      {{#if pages.about.mission}}
      <p class="mt-6 text-lg text-gray-500 max-w-2xl mx-auto leading-relaxed">
        {{pages.about.mission}}
      </p>
      {{/if}}
    </div>
  </section>

  {{> hero-decorations showDivider=true}}

  <!-- Our Story -->
  <section class="py-20 md:py-24 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="sr-hidden" data-sr-direction="up">
        <h2 class="text-xs font-semibold text-violet-600 uppercase tracking-wider mb-4">Our Story</h2>
        <div class="text-lg text-gray-600 leading-relaxed" style="white-space: pre-line;">{{pages.about.story}}</div>
      </div>
    </div>
  </section>

  <!-- Pull Quote -->
  {{#if pages.about.quote}}
  {{> hero-decorations showDivider=true}}
  <div class="sr-hidden" data-sr-direction="left">
    <section class="py-16 md:py-20 px-6">
      <div class="max-w-3xl mx-auto">
        <div class="border-l-4 border-violet-200 pl-6 md:pl-8">
          <span class="text-violet-200">{{{inlineSvg "quote" size="40" class="mb-4"}}}</span>
          <blockquote class="text-2xl md:text-3xl font-bold text-gray-900 leading-snug tracking-tight" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
            &ldquo;{{pages.about.quote.text}}&rdquo;
          </blockquote>
          <div class="mt-6 text-sm text-gray-500 font-medium">
            &mdash; {{pages.about.quote.author}}
          </div>
        </div>
      </div>
    </section>
  </div>
  {{/if}}

  <!-- Mission + Core Values -->
  <section class="py-20 md:py-24 px-6">
    <div class="max-w-4xl mx-auto">
      {{#if pages.about.mission}}
      <div class="sr-hidden" data-sr-direction="up">
        <div class="text-center mb-10">
          <span class="text-xs font-semibold text-violet-600 uppercase tracking-widest">Our Mission</span>
          <p class="mt-4 text-xl md:text-2xl font-medium text-gray-800 leading-relaxed italic max-w-2xl mx-auto" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
            &ldquo;{{pages.about.mission}}&rdquo;
          </p>
        </div>
      </div>
      {{/if}}

      <div class="sr-hidden" data-sr-direction="up">
        <div class="mb-12">
          <span class="text-xs font-semibold text-gray-400 uppercase tracking-widest">What We Stand For</span>
          <h2 class="mt-3 text-3xl md:text-4xl font-extrabold text-gray-950 tracking-tight" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
            Our Core Values
          </h2>
        </div>
      </div>

      <div class="space-y-8">
        {{#each pages.about.values}}
        <div class="sr-hidden" data-sr-direction="up" data-sr-delay="{{math @index '*' 120}}">
          <div class="flex items-start gap-6">
            <span class="text-5xl md:text-6xl font-extrabold text-gray-100 leading-none select-none shrink-0 w-16 md:w-20 text-right" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
              {{padIndex @index}}
            </span>
            <div class="pt-2 flex-1">
              <h3 class="font-bold text-gray-900 text-lg mb-1.5" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
                {{this.title}}
              </h3>
              <p class="text-sm text-gray-500 leading-relaxed">
                {{this.description}}
              </p>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
</div>
