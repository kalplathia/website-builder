      <a href="{{pageLink 'home'}}" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition-colors mb-6 no-underline">
        {{{inlineSvg "arrow-left" size="16"}}}Back to Home
