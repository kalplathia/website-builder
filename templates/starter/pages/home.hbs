<div>
  <!-- Hero (centered, full viewport) -->
  <section class="relative overflow-hidden min-h-[100vh] flex items-center">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-20%,rgba(124,58,237,0.08),transparent)]"></div>
    {{> hero-decorations showBlob=true showGrid=true patternId="home"}}
    <div class="relative max-w-3xl mx-auto px-6 text-center w-full">
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-gray-950 tracking-[-0.02em] leading-[1.08]" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
        {{pages.home.hero.headline}}
      </h1>
      <p class="mt-6 text-lg md:text-xl text-gray-500 max-w-2xl mx-auto leading-relaxed">
        {{pages.home.hero.subheadline}}
      </p>
      <div class="mt-8">
        <a href="{{pageLink 'contact'}}" class="inline-flex h-12 px-8 items-center rounded-full bg-gray-900 text-white text-sm font-semibold transition-all hover:ring-2 hover:ring-gray-900/10 hover:ring-offset-2 no-underline">
          {{pages.home.hero.ctaText}}
          {{{inlineSvg "arrow-right" size="16" class="ml-2"}}}
        </a>
      </div>
    </div>
  </section>

  <!-- Who We Are -->
  {{#if pages.home.miniAbout}}
  {{> hero-decorations showDivider=true}}
  <div class="sr-hidden" data-sr-direction="up">
    <section class="py-20 md:py-28 px-6" style="background: rgba(249,250,251,0.5);">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
          <div>
            <span class="text-xs font-semibold text-violet-600 uppercase tracking-widest">
              {{pages.home.miniAbout.tagline}}
            </span>
            <h2 class="mt-3 text-3xl md:text-4xl font-extrabold text-gray-950 tracking-tight" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
              Who We Are
            </h2>
            <p class="mt-5 text-lg text-gray-600 leading-relaxed">
              {{pages.home.miniAbout.shortDescription}}
            </p>
          </div>
          <div class="flex flex-wrap gap-3">
            {{#each pages.home.miniAbout.highlights}}
            <span class="inline-flex items-center gap-2.5 px-5 py-3 rounded-xl text-sm font-medium text-gray-700 {{#ifEq @index 0}}bg-violet-50 border border-violet-200{{else}}bg-white border border-gray-200{{/ifEq}}">
              {{{inlineSvg "check-circle" size="16" class="text-violet-500 shrink-0"}}}
              {{this}}
            </span>
            {{/each}}
          </div>
        </div>
      </div>
    </section>
  </div>
  {{/if}}

  <!-- Features -->
  <section class="py-20 md:py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="sr-hidden" data-sr-direction="up">
        <div class="mb-14">
          <span class="text-xs font-semibold text-gray-400 uppercase tracking-widest">What We Offer</span>
          <h2 class="mt-3 text-3xl md:text-4xl font-extrabold text-gray-950 tracking-tight" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
            Services &amp; Expertise
          </h2>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {{#each pages.home.features}}
        <div class="sr-hidden" data-sr-direction="up" data-sr-delay="{{math @index '*' 80}}">
          <div class="group bg-white rounded-2xl p-7 border border-gray-100 hover:border-violet-200 hover:shadow-lg transition-all duration-300 h-full" style="hover:box-shadow: 0 10px 15px -3px rgba(139,92,246,0.05);">
            <div class="w-11 h-11 rounded-xl bg-violet-50 flex items-center justify-center mb-5 group-hover:bg-violet-100 transition-colors">
              <span class="text-violet-600">{{{featureIcon this.icon}}}</span>
            </div>
            <h3 class="font-bold text-gray-900 mb-2" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">{{this.title}}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{{this.description}}</p>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>

  <!-- Stats -->
  {{#if pages.home.stats}}
  <section class="py-20 md:py-28 px-6 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        {{#each pages.home.stats}}
        <div class="sr-hidden" data-sr-direction="up" data-sr-delay="{{math @index '*' 120}}">
          <div class="bg-white rounded-2xl p-6 md:p-8 text-center border border-gray-100">
            <div class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
              {{this.value}}
            </div>
            <div class="mt-2 text-sm text-gray-500 font-medium">{{this.label}}</div>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/if}}

  {{> hero-decorations showDivider=true}}

  <!-- Testimonials -->
  {{#if pages.home.testimonials}}
  <section class="py-20 md:py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="sr-hidden" data-sr-direction="up">
        <div class="mb-14">
          <span class="text-xs font-semibold text-gray-400 uppercase tracking-widest">Testimonials</span>
          <h2 class="mt-3 text-3xl md:text-4xl font-extrabold text-gray-950 tracking-tight" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
            What Our Clients Say
          </h2>
        </div>
      </div>

      <!-- Featured testimonial -->
      <div class="sr-hidden" data-sr-direction="up">
        <div class="border-l-4 border-violet-200 pl-6 md:pl-8 mb-10">
          <span class="text-violet-200">{{{inlineSvg "quote" size="32" class="mb-4"}}}</span>
          <p class="text-xl md:text-2xl font-medium text-gray-800 leading-relaxed italic" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
            &ldquo;{{pages.home.testimonials.[0].quote}}&rdquo;
          </p>
          <div class="flex items-center gap-3 mt-6">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-violet-500 to-violet-600 flex items-center justify-center text-white text-sm font-bold shrink-0">
              {{initials pages.home.testimonials.[0].author}}
            </div>
            <div>
              <div class="text-sm font-semibold text-gray-900">{{pages.home.testimonials.[0].author}}</div>
              <div class="text-xs text-gray-500">{{pages.home.testimonials.[0].role}}</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Remaining testimonials -->
      {{#if (gt pages.home.testimonials.length 1)}}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {{#each pages.home.testimonials}}
        {{#if @index}}
        <div class="sr-hidden" data-sr-direction="up" data-sr-delay="{{math @index '*' 100}}">
          <div class="bg-white rounded-2xl p-7 border border-gray-100 flex flex-col h-full">
            <p class="text-gray-600 leading-relaxed flex-1">&ldquo;{{this.quote}}&rdquo;</p>
            <div class="flex items-center gap-3 mt-6 pt-5 border-t border-gray-100">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br {{testimonialAvatarColor (subtract @index 1)}} flex items-center justify-center text-white text-xs font-bold shrink-0">
                {{initials this.author}}
              </div>
              <div>
                <div class="text-sm font-semibold text-gray-900">{{this.author}}</div>
                <div class="text-xs text-gray-500">{{this.role}}</div>
              </div>
            </div>
          </div>
        </div>
        {{/if}}
        {{/each}}
      </div>
      {{/if}}
    </div>
  </section>
  {{/if}}

  <!-- CTA -->
  <section class="py-16 md:py-20 px-4 md:px-8">
    <div class="sr-hidden" data-sr-direction="scale">
      <div class="bg-gradient-to-br from-gray-900 via-gray-900 to-violet-950 rounded-3xl px-8 py-16 md:px-16 md:py-20 text-center">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white tracking-tight max-w-2xl mx-auto" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">
          {{pages.home.cta.headline}}
        </h2>
        <p class="mt-5 text-gray-400 leading-relaxed max-w-xl mx-auto text-lg">
          {{pages.home.cta.description}}
        </p>
        <div class="mt-10">
          <a href="{{pageLink 'contact'}}" class="inline-flex h-13 px-10 items-center rounded-full bg-white text-gray-900 text-sm font-semibold transition-all hover:ring-2 hover:ring-white/20 hover:ring-offset-2 hover:ring-offset-gray-900 no-underline" style="height: 3.25rem;">
            {{pages.home.cta.buttonText}}
            {{{inlineSvg "arrow-right" size="16" class="ml-2"}}}
          </a>
        </div>
      </div>
    </div>
  </section>
</div>
