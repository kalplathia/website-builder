<header id="site-header" class="sticky top-0 z-50 transition-all duration-300 backdrop-blur-xl" style="backdrop-filter: blur(24px) saturate(1.8); -webkit-backdrop-filter: blur(24px) saturate(1.8); background: rgba(255,255,255,0.4); border-bottom: 1px solid transparent;">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="{{pageLink 'home'}}" class="flex items-center gap-2.5 group no-underline">
      {{#if site.logo}}
        <img src="{{site.logo}}" alt="{{site.businessName}}" width="32" height="32" class="rounded-lg" />
      {{else}}
        <div class="w-8 h-8 rounded-lg bg-gray-900 text-white flex items-center justify-center text-sm font-bold">
          {{firstChar site.businessName}}
        </div>
      {{/if}}
      <span class="font-bold text-gray-900 text-[15px]" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">{{site.businessName}}</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      <a href="{{pageLink 'home'}}" class="relative px-4 py-2 text-sm font-medium rounded-lg transition-colors no-underline {{#ifEq currentPage 'home'}}text-gray-900 bg-gray-100/70{{else}}text-gray-500 hover:text-gray-900 hover:bg-gray-50{{/ifEq}}">
        Home
      </a>
      <a href="{{pageLink 'about'}}" class="relative px-4 py-2 text-sm font-medium rounded-lg transition-colors no-underline {{#ifEq currentPage 'about'}}text-gray-900 bg-gray-100/70{{else}}text-gray-500 hover:text-gray-900 hover:bg-gray-50{{/ifEq}}">
        About
      </a>
      <a href="{{pageLink 'contact'}}" class="relative px-4 py-2 text-sm font-medium rounded-lg transition-colors no-underline {{#ifEq currentPage 'contact'}}text-gray-900 bg-gray-100/70{{else}}text-gray-500 hover:text-gray-900 hover:bg-gray-50{{/ifEq}}">
        Contact
      </a>
      <div class="w-px h-5 bg-gray-200 mx-2"></div>
      <a href="{{pageLink 'contact'}}" class="ml-1 inline-flex h-9 px-5 items-center rounded-full bg-gray-900 text-white text-sm font-medium hover:bg-gray-800 transition-colors no-underline">
        Get in Touch
      </a>
    </nav>

    <button id="mobile-menu-btn" class="md:hidden relative w-10 h-10 flex items-center justify-center rounded-lg text-gray-600 hover:bg-gray-100 transition-colors" aria-label="Toggle menu">
      <svg id="menu-icon-open" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M3 6h14M3 10h14M3 14h14" />
      </svg>
      <svg id="menu-icon-close" class="hidden" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M5 5l10 10M15 5L5 15" />
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden border-t border-gray-100/50 bg-white/80 backdrop-blur-xl px-6 py-4 space-y-1 mobile-menu-enter" style="backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);">
    <a href="{{pageLink 'home'}}" class="block px-3 py-2.5 rounded-lg text-sm font-medium transition-colors no-underline {{#ifEq currentPage 'home'}}text-gray-900 bg-gray-100/70{{else}}text-gray-500 hover:text-gray-900 hover:bg-gray-50{{/ifEq}}">
      Home
    </a>
    <a href="{{pageLink 'about'}}" class="block px-3 py-2.5 rounded-lg text-sm font-medium transition-colors no-underline {{#ifEq currentPage 'about'}}text-gray-900 bg-gray-100/70{{else}}text-gray-500 hover:text-gray-900 hover:bg-gray-50{{/ifEq}}">
      About
    </a>
    <a href="{{pageLink 'contact'}}" class="block px-3 py-2.5 rounded-lg text-sm font-medium transition-colors no-underline {{#ifEq currentPage 'contact'}}text-gray-900 bg-gray-100/70{{else}}text-gray-500 hover:text-gray-900 hover:bg-gray-50{{/ifEq}}">
      Contact
    </a>
    <div class="pt-2">
      <a href="{{pageLink 'contact'}}" class="block w-full text-center py-2.5 rounded-full bg-gray-900 text-white text-sm font-medium hover:bg-gray-800 transition-colors no-underline">
        Get in Touch
      </a>
    </div>
  </nav>
</header>
