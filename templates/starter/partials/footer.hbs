<footer class="bg-gradient-to-b from-gray-900 to-gray-950 text-gray-400">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1 sr-hidden" data-sr-direction="up">
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm font-bold" style="background: rgba(139, 92, 246, 0.2); color: white;">
            {{firstChar site.businessName}}
          </div>
          <span class="font-bold text-white text-[15px]" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">{{site.businessName}}</span>
        </div>
      </div>

      <!-- Pages -->
      <div class="sr-hidden" data-sr-direction="up" data-sr-delay="100">
        <h4 class="text-xs font-semibold text-white uppercase tracking-wider mb-4">Pages</h4>
        <ul class="space-y-2.5 list-none p-0 m-0">
          <li><a href="{{pageLink 'home'}}" class="text-sm text-gray-400 hover:text-white transition-colors no-underline">Home</a></li>
          <li><a href="{{pageLink 'about'}}" class="text-sm text-gray-400 hover:text-white transition-colors no-underline">About Us</a></li>
          <li><a href="{{pageLink 'contact'}}" class="text-sm text-gray-400 hover:text-white transition-colors no-underline">Contact Us</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="sr-hidden" data-sr-direction="up" data-sr-delay="200">
        <h4 class="text-xs font-semibold text-white uppercase tracking-wider mb-4">Contact</h4>
        <ul class="space-y-3 list-none p-0 m-0">
          {{#if site.email}}
          <li>
            <a href="mailto:{{site.email}}" class="flex items-start gap-2.5 text-sm text-gray-400 hover:text-white transition-colors no-underline">
              {{{inlineSvg "mail" size="16" class="mt-0.5 shrink-0"}}}{{site.email}}
            </a>
          </li>
          {{/if}}
          {{#if site.phone}}
          <li>
            <a href="tel:{{site.phone}}" class="flex items-start gap-2.5 text-sm text-gray-400 hover:text-white transition-colors no-underline">
              {{{inlineSvg "phone" size="16" class="mt-0.5 shrink-0"}}}{{site.phone}}
            </a>
          </li>
          {{/if}}
          {{#if site.address}}
          <li class="flex items-start gap-2.5 text-sm">
            {{{inlineSvg "map-pin" size="16" class="mt-0.5 shrink-0"}}}{{site.address}}
          </li>
          {{/if}}
        </ul>
      </div>

      <!-- Legal -->
      <div class="sr-hidden" data-sr-direction="up" data-sr-delay="300">
        <h4 class="text-xs font-semibold text-white uppercase tracking-wider mb-4">Legal</h4>
        <ul class="space-y-2.5 list-none p-0 m-0">
          <li><a href="{{pageLink 'privacy'}}" class="text-sm text-gray-400 hover:text-white transition-colors no-underline">Privacy Policy</a></li>
          <li><a href="{{pageLink 'terms'}}" class="text-sm text-gray-400 hover:text-white transition-colors no-underline">Terms & Conditions</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs">
      <span>&copy; {{currentYear}} {{site.businessName}}. All rights reserved.</span>
    </div>
  </div>
</footer>
