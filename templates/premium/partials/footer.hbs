<!-- Footer -->
<footer class="bg-zinc-50 w-full pt-20 pb-10">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-12 px-8 max-w-screen-2xl mx-auto border-t border-zinc-200/10">
    <div class="md:col-span-1">
      <span class="text-2xl font-headline mb-6 block text-zinc-900">{{site.businessName}}</span>
      {{#if site.email}}
      <p class="font-body text-sm tracking-widest leading-relaxed text-zinc-500 mb-4">{{site.email}}</p>
      {{/if}}
      {{#if site.phone}}
      <p class="font-body text-sm tracking-widest leading-relaxed text-zinc-500">{{site.phone}}</p>
      {{/if}}
    </div>
    <div class="md:col-span-1">
      <h4 class="font-label text-xs uppercase tracking-[0.2em] text-zinc-900 mb-8">Navigation</h4>
      <ul class="space-y-4">
        <li><a class="{{#ifEq currentPage 'home'}}text-zinc-900 underline decoration-zinc-300 underline-offset-4{{else}}text-zinc-500 hover:text-zinc-900 transition-all{{/ifEq}} font-body text-sm tracking-widest leading-relaxed" href="{{pageLink 'home'}}">Home</a></li>
        <li><a class="{{#ifEq currentPage 'about'}}text-zinc-900 underline decoration-zinc-300 underline-offset-4{{else}}text-zinc-500 hover:text-zinc-900 transition-all{{/ifEq}} font-body text-sm tracking-widest leading-relaxed" href="{{pageLink 'about'}}">About Us</a></li>
        <li><a class="{{#ifEq currentPage 'contact'}}text-zinc-900 underline decoration-zinc-300 underline-offset-4{{else}}text-zinc-500 hover:text-zinc-900 transition-all{{/ifEq}} font-body text-sm tracking-widest leading-relaxed" href="{{pageLink 'contact'}}">Contact Us</a></li>
      </ul>
    </div>
    <div class="md:col-span-1">
      <h4 class="font-label text-xs uppercase tracking-[0.2em] text-zinc-900 mb-8">Legal</h4>
      <ul class="space-y-4">
        <li><a class="{{#ifEq currentPage 'privacy'}}text-zinc-900 underline decoration-zinc-300 underline-offset-4{{else}}text-zinc-500 hover:text-zinc-900 transition-all{{/ifEq}} font-body text-sm tracking-widest leading-relaxed" href="{{pageLink 'privacy'}}">Privacy Policy</a></li>
        <li><a class="{{#ifEq currentPage 'terms'}}text-zinc-900 underline decoration-zinc-300 underline-offset-4{{else}}text-zinc-500 hover:text-zinc-900 transition-all{{/ifEq}} font-body text-sm tracking-widest leading-relaxed" href="{{pageLink 'terms'}}">Terms & Conditions</a></li>
      </ul>
    </div>
    <div class="md:col-span-1">
      {{#if site.address}}
      <h4 class="font-label text-xs uppercase tracking-[0.2em] text-zinc-900 mb-8">Location</h4>
      <p class="font-body text-sm tracking-widest leading-relaxed text-zinc-500">{{site.address}}</p>
      {{/if}}
    </div>
  </div>
  <div class="max-w-screen-2xl mx-auto px-8 mt-20">
    <div class="editorial-line w-full mb-8"></div>
    <p class="font-body text-[10px] tracking-[0.4em] uppercase text-zinc-400 text-center">&copy; {{currentYear}} {{site.businessName}}. All rights reserved.</p>
  </div>
</footer>
