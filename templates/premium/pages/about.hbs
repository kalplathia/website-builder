<!-- Hero Section -->
<section class="px-8 pt-32 pb-24 max-w-screen-2xl mx-auto sr-hidden" data-sr-direction="up">
  <div class="editorial-grid">
    <div class="col-span-12 md:col-span-8">
      <span class="font-label text-xs tracking-[0.3em] text-secondary mb-6 block uppercase">Our Narrative</span>
      <h1 class="font-headline text-6xl md:text-8xl lg:text-9xl leading-[1.1] tracking-tighter text-primary">
        {{pages.about.mission}}
      </h1>
    </div>
    <div class="col-span-12 md:col-span-4 flex flex-col justify-end pb-4">
      <p class="font-body text-on-surface-variant text-lg leading-relaxed max-w-sm">
        {{site.description}}
      </p>
    </div>
  </div>
</section>

<!-- Visual Divider -->
<section class="w-full mb-40">
  <div class="aspect-[21/9] w-full relative overflow-hidden bg-gradient-to-r from-surface-container-high via-surface-container to-surface-container-low">
    <div class="absolute inset-0 bg-gradient-to-t from-background/40 to-transparent"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <span class="font-headline text-[12vw] text-outline-variant/10 tracking-tighter select-none">{{site.businessName}}</span>
    </div>
  </div>
</section>

<!-- Story Section -->
<section class="px-8 mb-48 max-w-screen-2xl mx-auto sr-hidden" data-sr-direction="up">
  <div class="editorial-grid">
    <div class="col-span-12 md:col-span-5 mb-12 md:mb-0">
      <h2 class="font-headline text-4xl mb-8">Our Story</h2>
      <div class="space-y-8 text-on-surface-variant text-sm leading-loose">
        <p>{{pages.about.story}}</p>
      </div>
    </div>
    {{#if pages.about.quote}}
    <div class="col-span-12 md:col-span-6 md:col-start-7">
      <div class="bg-surface-container-low p-12 lg:p-20 relative">
        <div class="absolute top-0 right-0 w-32 h-32 bg-surface-container-highest/50 translate-x-8 -translate-y-8 -z-10"></div>
        <p class="font-body text-2xl lg:text-3xl leading-[1.6] text-on-surface italic">
          "{{pages.about.quote.text}}"
        </p>
        <div class="mt-12 flex items-center gap-6">
          <div class="h-[1px] w-24 bg-outline-variant/30"></div>
          <span class="font-label text-xs tracking-[0.2em] uppercase">{{pages.about.quote.author}}</span>
        </div>
      </div>
    </div>
    {{/if}}
  </div>
</section>

<!-- Mission / Manifesto Section -->
<section class="bg-surface-container py-32 px-8 mb-48 sr-hidden" data-sr-direction="up">
  <div class="max-w-4xl mx-auto text-center">
    <span class="font-label text-xs tracking-[0.4em] text-secondary mb-12 block uppercase">Our Mission</span>
    <h2 class="font-headline text-4xl md:text-5xl lg:text-6xl mb-16 leading-tight">
      {{pages.about.mission}}
    </h2>
  </div>
</section>

<!-- Values Section -->
{{#if pages.about.values}}
<section class="px-8 mb-48 max-w-screen-2xl mx-auto sr-hidden" data-sr-direction="up">
  <div class="mb-16">
    <span class="font-label text-xs tracking-[0.3em] text-secondary mb-6 block uppercase">Our Values</span>
    <h2 class="font-headline text-5xl md:text-6xl">What We Believe</h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-0 border-t border-outline-variant/20">
    {{#each pages.about.values}}
    <div class="p-12 {{#unless @last}}border-b md:border-b-0 md:border-r{{/unless}} border-outline-variant/20 sr-hidden" data-sr-direction="up" data-sr-delay="{{math @index '*' 150}}">
      <span class="font-label text-xs tracking-widest text-secondary block mb-6">{{padIndex @index}}</span>
      <h3 class="font-headline text-2xl mb-6">{{title}}</h3>
      <p class="text-on-surface-variant text-sm leading-relaxed">{{description}}</p>
    </div>
    {{/each}}
  </div>
</section>
{{/if}}

<!-- Team Section -->
{{#if pages.about.team}}
<section class="px-8 mb-48 max-w-screen-2xl mx-auto sr-hidden" data-sr-direction="up">
  <div class="editorial-grid">
    <div class="col-span-12 md:col-span-6 mb-12 md:mb-0">
      <span class="font-label text-xs tracking-[0.3em] text-secondary mb-6 block uppercase">The Team</span>
      <h2 class="font-headline text-5xl md:text-6xl mb-12">Our People</h2>
      <div class="space-y-12">
        {{#each pages.about.team}}
        <div class="sr-hidden" data-sr-direction="left" data-sr-delay="{{math @index '*' 150}}">
          <h3 class="font-headline text-2xl mb-2">{{name}}</h3>
          <p class="font-label text-xs tracking-[0.2em] uppercase text-secondary mb-4">{{role}}</p>
          <p class="text-on-surface-variant text-sm leading-relaxed">{{bio}}</p>
        </div>
        {{/each}}
      </div>
    </div>
    <div class="col-span-12 md:col-span-6 md:col-start-7">
      <div class="aspect-[4/5] overflow-hidden bg-gradient-to-br from-surface-container-high to-surface-container flex items-center justify-center">
        <span class="font-headline text-8xl text-outline-variant/20 tracking-tighter select-none italic">Team</span>
      </div>
    </div>
  </div>
</section>
{{/if}}

<!-- CTA Section -->
<section class="px-8 mb-32 max-w-screen-2xl mx-auto sr-hidden" data-sr-direction="up">
  <div class="bg-primary text-on-primary py-24 px-12 md:px-24 flex flex-col items-center text-center">
    <h2 class="font-headline text-4xl md:text-5xl mb-8">Get in Touch</h2>
    <p class="font-body text-on-primary-container text-lg max-w-xl mb-12">
      We invite you to explore what we can create together.
    </p>
    <a href="{{pageLink 'contact'}}" class="bg-surface-container-lowest text-primary px-10 py-3 font-label tracking-widest text-xs uppercase hover:bg-surface-container-high transition-colors">
      Contact Us
    </a>
  </div>
</section>
